GROQ_API_KEY=
# Relay C-2 (opcional, fase escritorio+móvil): base http(s) del relay.
# RUTSUBO_RELAY_URL=http://127.0.0.1:8443
# Relay C-2 — identidad Google (ADR-009). Client IDs aceptados como `aud`:
# GOOGLE_CLIENT_IDS=xxx.apps.googleusercontent.com,yyy.apps.googleusercontent.com
# Modo desarrollo (acepta id_tokens de prueba dev:{sub}:{email}; NO en red pública):
# RELAY_GOOGLE_DEV=1
# TTL corto del buzón para probar expiración (por defecto 7 días):
# RELAY_OUTBOX_TTL_SECS=60
